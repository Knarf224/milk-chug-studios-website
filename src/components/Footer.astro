---
const year = new Date().getFullYear()
---

<footer>
  <div class="container">
    <p>© {year} Milk Chug Studios. All rights reserved.</p>
    <a href="/privacy">Privacy Policy</a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 5rem;
  }

  footer .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  footer p {
    text-align: center;
    color: var(--muted);
    font-size: 0.875rem;
  }

  footer a {
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: underline;
    transition: color 0.15s;
  }

  footer a:hover {
    color: var(--text);
  }
</style>
