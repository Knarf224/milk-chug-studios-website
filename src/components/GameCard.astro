---
const { title, slug, description, play_count, cover } = Astro.props
---

<a href={`/games/${slug}`} class="card">
  <div class="cover">
    {cover
      ? <img src={cover} alt={title} />
      : <div class="placeholder"><span>▶</span></div>
    }
  </div>
  <div class="info">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    <div class="meta">
      <span class="plays">▶ {play_count ?? 0} plays</span>
      <span class="cta">Play →</span>
    </div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
  }

  .cover {
    aspect-ratio: 16 / 9;
    background: var(--border);
    overflow: hidden;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .card:hover .cover img {
    transform: scale(1.03);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e5e2d9, #ccc9be);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder span {
    font-size: 2rem;
    opacity: 0.3;
  }

  .info {
    padding: 1.25rem;
  }

  .info h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }

  .info p {
    font-size: 0.875rem;
    color: var(--muted);
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .plays {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .cta {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent-dark);
  }
</style>
