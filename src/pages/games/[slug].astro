---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { supabase } from '../../lib/supabase.js'

export async function getStaticPaths() {
  const { data: games } = await supabase.from('games').select('*')
  return (games ?? []).map(game => ({
    params: { slug: game.slug },
    props: { game },
  }))
}

const { game } = Astro.props
const comingSoon = !game.live
---

<BaseLayout title={game.title}>
  <section class="page">
    <div class="container">
      <a href="/games" class="back">← All Games</a>
      <h1>{game.title}</h1>
      {game.description && <p class="description">{game.description}</p>}

      {comingSoon ? (
        <div class="coming-soon">
          <span class="cs-icon">⚡</span>
          <h2>Coming Soon</h2>
          <p>This game is currently in development. Check back soon!</p>
        </div>
      ) : (
        <>
          <div class="embed-wrapper" data-slug={game.slug}>
            <iframe
              src={`/games/${game.slug}/index.html`}
              allowfullscreen
              title={game.title}
            ></iframe>
          </div>
          <div class="game-footer">
            <p class="play-count" id="play-count">▶ {game.play_count} plays</p>
            {game.slug === 'power-thief' && (
              <a href={`/games/${game.slug}/leaderboard`} class="leaderboard-link">⚔ View Leaderboard</a>
            )}
          </div>
        </>
      )}
    </div>
  </section>
</BaseLayout>

{!comingSoon && (
  <script>
    import { supabase } from '../../lib/supabase.js'

    const SUPABASE_ORIGIN = 'https://sbwmznwbfjcnnmgqvifv.supabase.co'

    // ── Approach A: postMessage relay (game sends gdnet_req, parent fetches) ────
    window.addEventListener('message', async (e: MessageEvent) => {
      if (!e.data || e.data.type !== 'gdnet_req') return
      const { id, method, path, headers, body } = e.data
      try {
        const opts: RequestInit = { method, headers }
        if (body) opts.body = atob(body)
        const res = await fetch(SUPABASE_ORIGIN + path, opts)
        const text = await res.text()
        ;(e.source as Window).postMessage({ type: 'gdnet_res', id, status: res.status, body: text }, '*')
      } catch (_err) {
        ;(e.source as Window).postMessage({ type: 'gdnet_res', id, status: 0, body: '' }, '*')
      }
    })

    // ── Approach B: fetch override in iframe (fallback for older exports) ───────
    const gameIframe = document.querySelector('iframe') as HTMLIFrameElement | null
    if (gameIframe) {
      gameIframe.addEventListener('load', () => {
        const iwin = gameIframe.contentWindow as any
        if (!iwin || !iwin.fetch) return
        const nativeFetch = iwin.fetch.bind(iwin)
        iwin.fetch = (url: any, opts: any) => {
          if (typeof url === 'string' && url.startsWith(SUPABASE_ORIGIN)) {
            return fetch(url, opts)
          }
          return nativeFetch(url, opts)
        }
      })
    }

    // ── Play count ─────────────────────────────────────────────────────────────
    const wrapper = document.querySelector('.embed-wrapper') as HTMLElement
    const slug = wrapper?.dataset.slug

    if (slug) {
      const { data: current } = await supabase
        .from('games')
        .select('play_count')
        .eq('slug', slug)
        .single()

      if (current) {
        const newCount = (current.play_count ?? 0) + 1
        await supabase
          .from('games')
          .update({ play_count: newCount })
          .eq('slug', slug)

        const counter = document.getElementById('play-count')
        if (counter) counter.textContent = `▶ ${newCount} plays`
      }
    }
  </script>
)}

<style>
  .page {
    padding: 4rem 0;
  }

  .back {
    display: inline-block;
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--text);
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 0.5rem;
  }

  .description {
    color: var(--muted);
    margin-bottom: 2rem;
    max-width: 600px;
  }

  .coming-soon {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 12px;
    border: 2px dashed var(--border);
    background: var(--card-bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    text-align: center;
  }

  .cs-icon {
    font-size: 3rem;
  }

  .coming-soon h2 {
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -1px;
    color: var(--text);
  }

  .coming-soon p {
    color: var(--muted);
    font-size: 1rem;
  }

  .embed-wrapper {
    width: 100%;
    aspect-ratio: 8 / 3;
    min-height: 720px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
    margin-bottom: 1rem;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .game-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .play-count {
    color: var(--muted);
    font-size: 0.875rem;
  }

  .leaderboard-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    transition: color 0.15s;
  }

  .leaderboard-link:hover {
    color: var(--accent-dark);
  }
</style>
