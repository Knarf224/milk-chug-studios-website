---
import BaseLayout from '../layouts/BaseLayout.astro'

const stack = [
  { icon: '🎮', name: 'Godot 4', role: 'Game Engine' },
  { icon: '🚀', name: 'Astro', role: 'Website Framework' },
  { icon: '▲', name: 'Vercel', role: 'Hosting' },
  { icon: '🗄️', name: 'Supabase', role: 'Database' },
]
---

<BaseLayout title="About">

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <span class="label">About the Studio</span>
      <h1>One Man.<br/>One Mission.<br/><em>Make Games.</em></h1>
    </div>
  </section>

  <!-- Mission -->
  <section class="mission">
    <div class="container">
      <div class="mission-grid">
        <div class="mission-text">
          <h2>What is Milk Chug Studios?</h2>
          <p>
            Milk Chug Studios is a one-person indie game studio built from scratch.
            Every game here is made by someone learning in public — experimenting,
            shipping, and getting better with each release.
          </p>
          <p>
            No publishers. No investors. No crunch. Just a genuine love for making
            things and putting them in front of people.
          </p>
        </div>
        <div class="mission-card">
          <p class="mission-quote">
            "Build games worth playing.<br/>Share the journey openly.<br/>Grow one release at a time."
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Currently Building -->
  <section class="current">
    <div class="container">
      <h2>Currently Building</h2>
      <div class="current-card">
        <div class="current-info">
          <span class="badge">In Development</span>
          <h3>Power Thief</h3>
          <p>
            A top-down roguelike where you steal power cores from enemies and combine
            them to create new abilities. Built in Godot 4.
          </p>
          <a href="/games/power-thief" class="btn">Play Now →</a>
        </div>
        <div class="current-visual">⚡</div>
      </div>
    </div>
  </section>

  <!-- Stack -->
  <section class="stack">
    <div class="container">
      <h2>The Stack</h2>
      <p class="stack-sub">Everything used to build and run this studio — all free and open source.</p>
      <div class="stack-grid">
        {stack.map(item => (
          <div class="stack-card">
            <span class="stack-icon">{item.icon}</span>
            <strong>{item.name}</strong>
            <span>{item.role}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: var(--text);
    color: var(--bg);
    padding: 6rem 0;
  }

  .label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -2px;
    line-height: 1.1;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent);
  }

  /* Mission */
  .mission {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .mission-text h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 1.25rem;
  }

  .mission-text p {
    color: var(--muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .mission-card {
    background: var(--accent);
    border-radius: 16px;
    padding: 2.5rem;
  }

  .mission-quote {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1.6;
    color: var(--text);
  }

  /* Currently Building */
  .current {
    padding: 5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .current h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 2rem;
  }

  .current-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .badge {
    display: inline-block;
    background: var(--accent);
    color: var(--text);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  .current-info h3 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 0.75rem;
  }

  .current-info p {
    color: var(--muted);
    line-height: 1.75;
    max-width: 480px;
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-block;
    background: var(--text);
    color: var(--bg);
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    transition: opacity 0.15s;
  }

  .btn:hover {
    opacity: 0.8;
  }

  .current-visual {
    font-size: 6rem;
    line-height: 1;
    flex-shrink: 0;
  }

  /* Stack */
  .stack {
    padding: 5rem 0;
  }

  .stack h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 0.5rem;
  }

  .stack-sub {
    color: var(--muted);
    margin-bottom: 2.5rem;
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .stack-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: transform 0.15s, box-shadow 0.15s;
  }

  .stack-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }

  .stack-icon {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }

  .stack-card strong {
    font-size: 1rem;
    font-weight: 700;
  }

  .stack-card span {
    font-size: 0.85rem;
    color: var(--muted);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .current-card {
      flex-direction: column;
      text-align: center;
    }

    .current-visual {
      font-size: 4rem;
    }
  }
</style>
